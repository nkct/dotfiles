export DOTFILES_DIR="$HOME/dotfiles"

export BROWSER="firefox"
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_DATA_HOME="$HOME/.local/share"

# set EDITOR: prefer vim if 'huge' or 'full', else nano if present, else vi
vimver=$(vim --version 2>/dev/null || echo "")
if echo "$vimver" | grep -qiE 'huge|full'; then
  export EDITOR="vim"
elif command -v nano >/dev/null 2>&1; then
  export EDITOR="nano"
else
  export EDITOR="vi"
fi

if command -v code >/dev/null 2>&1; then
  export VISUAL="code"
else
  export VISUAL="${EDITOR:-vi}"
fi

# WSL specifics
export IS_WSL=0
if grep -q 'WSL' /proc/sys/kernel/osrelease 2>/dev/null; then
  export IS_WSL=1
  export WSL_HOST_IP="$(awk '/nameserver / {print $2; exit}' /etc/resolv.conf)"
  export BROWSER="/mnt/c/Program Files/Mozilla Firefox/firefox.exe"
fi

